# Telegram API credentials from https://my.telegram.org
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash

# Recommended for Docker/VPS: generate with `python generate_session.py`, then paste the value here.
TG_SESSION=

# Optional fallback for local development when TG_SESSION is empty.
TELEGRAM_SESSION_NAME=my_account

# Captcha listener settings.
CAPTCHA_ENABLED=true
CAPTCHA_DEBUG=true

# Comma-separated chat IDs or usernames. Leave empty to watch all visible chats.
CAPTCHA_CHATS=

# Comma-separated bot usernames without @. Leave empty to accept all senders.
CAPTCHA_BOTS=easfake

# Comma-separated trigger keywords.
CAPTCHA_KEYWORDS=人机验证,请选择计算结果,完成验证,验证码,captcha,verify,calculation result

# Delay before clicking the answer button, in seconds.
CAPTCHA_CLICK_DELAY=15

# OCR is optional. Enable only if captcha messages use images with math text.
CAPTCHA_OCR=false
CAPTCHA_TIMEOUT=20

DOWNLOAD_DIR=downloads
STATS_INTERVAL=60
